{
  "name": "remotepass-playwright-typescript-ui-test",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ci": "playwright test --quiet",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "report:html": "playwright show-report playwright-report/html",
    "report:allure": "allure generate allure-results -o allure-report --clean && allure open allure-report",
    "report": "npm run report:html",
    "clean": "rm -rf playwright-report allure-report allure-results test-results",
    "format": "prettier --write 'src/**/*.{js,ts,tsx}'",
    "lint": "eslint 'src/**/*.{js,ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{js,ts,tsx}' --fix",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "allure-playwright": "^3.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "fsevents": "^2.3.2",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "undici-types": "^7.18.2"
  }
}
